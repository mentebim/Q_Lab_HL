    "features": [
      {
        "name": "ret_1h",
        "kind": "return",
        "lookback": 1,
        "transform": "zscore",
        "clip": 3.0
      }
    ]
  },
  "execution_overrides": {
    "rebalance_every_bars": 24
  },
  "data_dir": "data/market_cache_1h",
